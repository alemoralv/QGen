# Copy to ".env.local" for local development.
# On Vercel, set these under Project Settings → Environment Variables.

# Gateway base URL (OpenAI-compatible). No trailing slash.
# This is not a secret — it lives server-side and is never sent to the browser.
GW_BASE_URL=https://ca-sandbox-gateway-llm-eastus.proudtree-e258edc9.eastus.azurecontainerapps.io

# Model id served by the gateway.
GW_CHAT_MODEL=gpt-4.1-mini

# GW_GATEWAY_API_KEY is intentionally NOT set here.
# Each user supplies their own gw_... key through the web UI.
# The key is passed to the server only in the x-gw-api-key request header.
